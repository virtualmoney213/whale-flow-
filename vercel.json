export default async function handler(req, res) {
  // Allow your dashboard to call this proxy
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'GET, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');

  // Handle preflight
  if (req.method === 'OPTIONS') {
    return res.status(200).end();
  }

  // Only allow GET
  if (req.method !== 'GET') {
    return res.status(405).json({ error: 'Method not allowed' });
  }

  try {
    // Get the path and query from the request
    // e.g. /api/proxy?path=/api/option-trades/flow-alerts&limit=20
    const { path, ...queryParams } = req.query;

    if (!path) {
      return res.status(400).json({ error: 'Missing path parameter' });
    }

    // Build the Unusual Whales URL
    const base = 'https://api.unusualwhales.com';
    const url = new URL(base + path);

    // Append any extra query params
    Object.entries(queryParams).forEach(([k, v]) => {
      url.searchParams.set(k, v);
    });

    // Use the API key from Vercel environment variable (never exposed to browser)
    const apiKey = process.env.UW_API_KEY;
    if (!apiKey) {
      return res.status(500).json({ error: 'API key not configured on server' });
    }

    // Make the real request to Unusual Whales
    // UW-CLIENT-API-ID is required per official docs
    const response = await fetch(url.toString(), {
      headers: {
        'Authorization': `Bearer ${apiKey}`,
        'Content-Type': 'application/json',
        'UW-CLIENT-API-ID': '100001',
      },
    });

    if (!response.ok) {
      const errText = await response.text();
      return res.status(response.status).json({
        error: `Unusual Whales API error: ${response.status}`,
        detail: errText,
      });
    }